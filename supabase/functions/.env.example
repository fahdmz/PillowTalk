# Copy to `.env` in this directory for local `supabase functions serve`
# testing only. Never commit the real `.env` — it holds a Google Cloud
# service-account private key. In production, set these as Edge Function
# secrets instead (Dashboard > Edge Functions > google-tts > Secrets, or
# `supabase secrets set --env-file`), not via a tracked file.

# Full Google Cloud service-account JSON (single line), scoped to a service
# account with permission to call Cloud Text-to-Speech.
GOOGLE_TTS_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# Optional: overrides the deployed Indonesian wind-down voice without a new
# app build. Defaults to id-ID-Wavenet-A (calm female voice) if unset.
GOOGLE_TTS_VOICE_ID=id-ID-Wavenet-A
