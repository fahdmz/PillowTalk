# Application
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Supabase (backend only)
# Project Settings > API. New sb_secret_ keys are supported.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Supabase Auth publishes asymmetric JWT verification keys at:
# ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_CACHE_SECONDS=600
SUPABASE_JWKS_TIMEOUT_SECONDS=10

# Azure AI Foundry model inference (backend only)
# Do not include /openai/v1; the backend appends it.
AZURE_AI_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_AI_FOUNDRY_API_KEY=your-foundry-api-key
AZURE_AI_FOUNDRY_CHAT_DEPLOYMENT=your-gpt-5-deployment-name
AZURE_AI_FOUNDRY_CLASSIFIER_DEPLOYMENT=your-gpt-5-mini-deployment-name
# May reuse the classifier deployment; if omitted, the backend does that automatically.
AZURE_AI_FOUNDRY_RECAP_DEPLOYMENT=your-gpt-5-mini-deployment-name
AZURE_AI_FOUNDRY_TIMEOUT_SECONDS=30
AZURE_AI_FOUNDRY_MAX_RETRIES=2
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=

# Local pretrained Indonesian emotion classifier
# Evaluate on PillowTalk data and pin a commit hash before production.
EMOTION_MODEL_ID=mrezadit/indobert-emotion-classification
EMOTION_MODEL_REVISION=main
HF_TOKEN=
EMOTION_MODEL_DEVICE=cpu
EMOTION_LOCAL_CONFIDENCE_THRESHOLD=0.65
EMOTION_FALLBACK_ENABLED=true

# Chat context, output, and per-process abuse protection
CHAT_RECENT_MESSAGE_LIMIT=12
CHAT_MEMORY_SESSION_LIMIT=3
CHAT_MEMORY_LOOKBACK_DAYS=14
CHAT_MAX_OUTPUT_TOKENS=800
CHAT_RATE_LIMIT_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
# Hard cap on user messages per check-in — ends the session even if the
# model never signals should_close.
CHAT_MAX_USER_TURNS=8

# Completed-session recap generation
RECAP_MAX_OUTPUT_TOKENS=500
RECAP_GENERATION_INPUT_LIMIT=200

# Safety behavior (not a substitute for emergency services)
SAFETY_HIGH_RISK_THRESHOLD=0.85
CRISIS_RESOURCE_NAME=Healing119
CRISIS_RESOURCE_PHONE=119 ext. 8
CRISIS_RESOURCE_URL=https://www.healing119.id
