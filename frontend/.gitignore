# Coverage
coverage/

# Platform folders generated by `flutter create .` are checked in once
# created (they'll bring their own nested .gitignore for Gradle/Pods/Xcode
# build output); only pre-declare the common build dirs here so nothing
# leaks before that command has been run.
android/.gradle/
android/app/debug
android/app/profile
android/app/release
android/local.properties
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/DerivedData/
ios/*.xcuserstate
